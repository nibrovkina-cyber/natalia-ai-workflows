# MAX Bot Migration - Configuration
# Copy to config.env and fill in your values

# MAX Bot token
# Where to get: business.max.ru > Чат-боты > Интеграция > Получить токен
BOT_TOKEN=your_max_bot_token_here

# Admin chat ID in MAX (for receiving booking/lead notifications)
# How to find: send any message to your bot, then check bot console output for chat_id
ADMIN_CHAT_ID=your_admin_chat_id

# Optional: Claude API for smart responses to unknown questions
# Where to get: console.anthropic.com > API Keys
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Bankruptcy Deal Finder — Configuration
# Copy this file to config.env and fill in your values

# Claude API key (for market price analysis)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Telegram bot (create via @BotFather in Telegram)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=your-chat-id

# Search criteria
REGIONS=moscow,mo,spb
ASSET_TYPES=apartment,commercial,parking
MIN_DISCOUNT=25
MAX_PRICE=15000000

# Scan schedule
SCAN_INTERVAL=daily

# Optional: parser-api.com for bankrot.fedresurs.ru structured data
# PARSER_API_KEY=your-key-here

# Marketplace AI Manager — Configuration
# Copy to config.env and fill in

# WB API key (seller dashboard > Settings > API Access > all permissions)
WB_TOKEN=your_wb_api_token

# Claude API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Telegram bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Competitor monitoring (comma-separated WB article IDs)
COMPETITOR_SKUS=67890,11111,22222

# Inventory alert thresholds
MIN_STOCK_DEFAULT=50
DAYS_SUPPLY_ALERT=5

# Review check interval (minutes)
REVIEW_INTERVAL=30

# Competitor check interval (hours)
COMPETITOR_INTERVAL=6

# Daily briefing time (24h format, MSK)
BRIEFING_TIME=08:00

# Optional: Ozon API (if selling on both platforms)
# OZON_CLIENT_ID=your_client_id
# OZON_API_KEY=your_ozon_key

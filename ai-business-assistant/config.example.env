# AI Business Assistant — Configuration
# Copy this file to config.env and fill in your values

# Claude API key (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Your email (for filtering out self-sent emails)
GMAIL_USER_EMAIL=you@example.com

# Path to your business context file
BUSINESS_CONTEXT_FILE=./my-business.md

# Your timezone (for calendar and briefing times)
TIMEZONE=Europe/Moscow

# How many emails to scan (most recent N unread)
MAX_EMAILS_TO_SCAN=20

# Metrics source (optional, leave blank if not using)
# METRICS_SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/your-id
# METRICS_DASHBOARD_URL=https://your-dashboard.com

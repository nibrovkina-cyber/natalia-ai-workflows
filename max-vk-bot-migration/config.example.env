# MAX/VK Bot — Configuration
# Copy to config.env and fill in

# MAX Bot token (from business.max.ru > Чат-боты > Интеграция > Получить токен)
BOT_TOKEN=your_max_bot_token_here

# Admin chat ID in MAX (for receiving booking/lead notifications)
ADMIN_CHAT_ID=your_admin_chat_id

# Optional: Claude API for smart responses to unknown questions
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: VK community token (if running VK version too)
# VK_TOKEN=your_vk_community_token
# VK_GROUP_ID=your_group_id
